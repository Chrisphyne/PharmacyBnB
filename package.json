{
  "name": "kenyan-pharmacy-ai-system",
  "version": "1.0.0",
  "description": "AI-Enabled Pharmacy Services & Inventory Management System for Kenyan Pharmacies",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/server.js",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/server.js",
    "setup": "npm run db:setup && npm run seed",
    "db:setup": "node server/scripts/setup-db.js",
    "seed": "node server/scripts/seed-data.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "prisma": "^5.7.1",
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "langchain": "^0.0.212",
    "chromadb": "^1.7.3",
    "@langchain/openai": "^0.0.14",
    "@langchain/community": "^0.0.20",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "socket.io": "^4.7.4",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "moment": "^2.29.4",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "pharmacy",
    "AI",
    "inventory",
    "kenya",
    "healthcare",
    "voice-assistant"
  ],
  "author": "Kenyan Pharmacy AI Team",
  "license": "MIT"
}